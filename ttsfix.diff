+// GetTTSMode returns the current TTS mode safely.
+func (c *TTSCfg) GetTTSMode() string {
+	c.mu.RLock()
+	defer c.mu.RUnlock()
+	if c.ttsMode == "" {
+		return "voice_only"
+	}
+	return c.ttsMode
+}
+
+// SetTTSMode updates the TTS mode safely.
+func (c *TTSCfg) SetTTSMode(mode string) {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.ttsMode = mode
 }
 
